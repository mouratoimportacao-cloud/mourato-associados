generator client {
  provider = "prisma-client-js"
  engineType = "library"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
id                Int      @id @default(autoincrement())
nome              String
email             String   @unique
senha             String
tipo              String
documento         String?
telefone          String?
endereco          String?
cidade            String?
estado            String?
cep               String?
status            String?   @default("pendente")
codigoRevenda     String?
estoquePessoal    String?   @db.Text
createdAt         DateTime  @default(now())
}

model Produto {
id                      Int      @id @default(autoincrement())
nome                    String
marca                   String
categoria               String
volume                  String
preco                   Float?
estoque                 Int      @default(0)
descricao               String?
imagem                  String?
createdAt               DateTime @default(now())
categoria_principal     String?
tags                    String?
concentracao            String?
origem                  String?
tipo_perfume            String?
genero                  String?
familia_olfativa        String?
notas_topo              String?
notas_coracao           String?
notas_fundo             String?
fixacao_estimada        String?
projecao                String?
ocasiao_uso             String?
similaridade_inspiracao String?
descricao_olfativa      String?
}

model Pedido {
id                      Int      @id @default(autoincrement())
usuarioId               Int
produtoId               Int?
produtoNome             String?
quantidade              Int?
precoUnitario           Float?
precoTabela             Float?
custoUnitario           Float?
descontoConcedido       Float?   @default(0)
lucroBruto              Float?   @default(0)
tipoFluxo               String?
quantidadePagaFornecedor Int?
totalPagoFornecedor     Float?
saldoFornecedor         Float?
pagamento               String?
observacao              String?
total                   Float
status                  String
createdAt               DateTime @default(now())
}

model Endereco {
id        Int      @id @default(autoincrement())
usuarioId Int
cep       String
rua       String
numero    String
bairro    String
cidade    String
estado    String
}
