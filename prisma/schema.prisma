generator client {
  provider = "prisma-client-js"
  engineType = "library"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"

}

model Usuario {
id                Int      @id @default(autoincrement())
nome              String
email             String   @unique
senha             String
tipo              String
documento         String?
telefone          String?
endereco          String?
cidade            String?
estado            String?
cep               String?
status            String?   @default("pendente")
codigoRevenda     String?
estoquePessoal    String?   @db.Text
createdAt         DateTime  @default(now())
}

model Produto {
id                      Int      @id @default(autoincrement())
nome                    String
marca                   String
categoria               String
volume                  String
preco                   Float?
estoque                 Int      @default(0)
descricao               String?
imagem                  String?
createdAt               DateTime @default(now())
categoria_principal     String?
tags                    String?
concentracao            String?
origem                  String?
tipo_perfume            String?
genero                  String?
familia_olfativa        String?
notas_topo              String?
notas_coracao           String?
notas_fundo             String?
fixacao_estimada        String?
projecao                String?
ocasiao_uso             String?
similaridade_inspiracao String?
descricao_olfativa      String?
}

model Pedido {
id                      Int      @id @default(autoincrement())
usuarioId               Int
produtoId               Int?
produtoNome             String?
quantidade              Int?
precoUnitario           Float?
precoTabela             Float?
custoUnitario           Float?
descontoConcedido       Float?   @default(0)
lucroBruto              Float?   @default(0)
tipoFluxo               String?
quantidadePagaFornecedor Int?
totalPagoFornecedor     Float?
saldoFornecedor         Float?
pagamento               String?
observacao              String?
total                   Float
status                  String
createdAt               DateTime @default(now())
}

model Endereco {
id        Int      @id @default(autoincrement())
usuarioId Int
cep       String
rua       String
numero    String
bairro    String
cidade    String
estado    String
}

model Despesa {
id          Int      @id @default(autoincrement())
data        DateTime
categoria   String
valor       Float
observacao  String?
createdAt   DateTime @default(now())
}

model FechamentoMensal {
id             Int      @id @default(autoincrement())
mesAno         String   @unique
receitaAtacado Float
receitaSite    Float
receitaTotal   Float
cmv            Float
valorEstoque   Float
totalDespesas  Float
saldoBancario  Float
resultado      Float
dadosDespesas  Json?
createdAt      DateTime @default(now())
}
model LancamentoFinanceiro {
id          Int      @id @default(autoincrement())
data        DateTime
competencia String
tipo        String
grupo       String
categoria   String
valor       Float
observacao  String?
createdAt   DateTime @default(now())
}

model FechamentoFinanceiro {
id                    Int      @id @default(autoincrement())
competencia           String   @unique
fechadoEm              DateTime
receitaAtacado         Float
receitaSite            Float
receitaTotal           Float
cmv                    Float
estoque                 Float
contasReceber          Float
totalDespesas          Float
saldoBancario          Float
resultadoOperacional   Float
despesasPorCategoria   String   @db.Text
createdAt              DateTime @default(now())
}

model Lead {
  id         Int      @id @default(autoincrement())
  nome       String
  contato    String
  cidade     String?
  estado     String?
  endereco   String?  @db.Text
  produtos   String?  @db.Text
  total      Float?
  status     String   @default("Novo")
  createdAt  DateTime @default(now())
}

// Novos modelos para multi‑lojista
model SupplierStock {
  id        Int      @id @default(autoincrement())
  productId Int
  quantity  Int
  cost      Decimal
  updatedAt DateTime @updatedAt
}

model RetailerStock {
  id          Int      @id @default(autoincrement())
  retailerId  Int
  productId   Int
  quantity    Int
  cost        Decimal
  updatedAt   DateTime @updatedAt
}

enum PurchaseStatus {
  AGUARDANDO_PAGAMENTO
  PAGO
  ENVIADO
  ENTREGUE
  CANCELADO
}

model RetailerPurchase {
  id               Int               @id @default(autoincrement())
  retailerId       Int
  supplierId       Int
  status           PurchaseStatus
  totalAmount      Decimal
  paidAmount       Decimal
  openAmount       Decimal
  stockTransferred Boolean   @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  items            RetailerPurchaseItem[] @relation("RetailerPurchaseItems")
  packages         Package[]
}

model Package {
  id Int @id @default(autoincrement())
  retailerPurchaseId Int
  totalAmount Decimal
  paidAmount Decimal
  openAmount Decimal
  status String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  retailerPurchase RetailerPurchase @relation(fields: [retailerPurchaseId], references: [id])
}


model RetailerPurchaseItem {
  id Int @id @default(autoincrement())
  purchaseId Int
  productId Int
  quantity Int
  unitCost Decimal
  totalCost Decimal
  purchase RetailerPurchase @relation("RetailerPurchaseItems", fields: [purchaseId], references: [id])
}

enum OwnerType {
  ADMIN
  FORNECEDOR
  LOJISTA
}

enum EntryType {
  RECEITA
  DESPESA
  RECEBIMENTO
  PAGAMENTO
  CONTA_A_RECEBER
  CONTA_A_PAGAR
  ESTORNO
}

enum EntrySource {
  PUBLIC_SALE
  QR_SALE
  RETAILER_PURCHASE
  RETAILER_PAYMENT
  REFUND
  ADJUSTMENT
}

enum EntryStatus {
  PAGO
  EM_ABERTO
  CANCELADO
}

enum PaymentStatus {
  PAGO
  EM_ABERTO
  CANCELADO
}

model FinancialEntry {
  id          Int        @id @default(autoincrement())
  ownerType   OwnerType
  ownerId     Int
  retailerId  Int?
  type        EntryType
  source      EntrySource
  amount      Decimal
  status      EntryStatus
  referenceId Int?
  description String?
  createdAt   DateTime @default(now())
}

model PublicOrder {
  id            Int          @id @default(autoincrement())
  productId     Int
  quantity      Int
  unitPrice     Decimal
  total         Decimal
  paymentStatus PaymentStatus
  ownerType     OwnerType @default(FORNECEDOR)
}

model QrOrder {
  id           Int          @id @default(autoincrement())
  retailerId   Int
  productId    Int
  quantity     Int
  unitPrice    Decimal
  total        Decimal
  paymentStatus PaymentStatus
}
